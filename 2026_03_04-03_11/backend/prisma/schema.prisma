generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Post {
  id       Int       @id @default(autoincrement())
  title    String
  body     String
  userId   Int
  comments Comment[]
}

model Comment {
  id     Int    @id @default(autoincrement())
  name   String
  email  String
  body   String
  postId Int
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
}
